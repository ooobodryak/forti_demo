<%# Строка таблицы Пациентов.
  #
  # Обязательные.
  # @param [Patient] patient Пациент.
%>

<tr>
  <td><%= patient.first_name %></td>
  <td><%= patient.last_name %></td>
  <td><%= patient.age %></td>
  <td class="text-center">
    <% if (recipe_count = patient.recipes.count) > 0 %>
      <%= link_to recipes_path(q: { patient_id_eq: patient.id }),
          class: "btn btn-sm btn-light border position-relative",
          title: "Показать все рецепты этого пациента" do %>
        <i class="bi bi-file-earmark-medical"></i>
        Рецепты
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary">
          <%= recipe_count %>
        </span>
      <% end %>
    <% end %>
  </td>
  <td class="pe-3 py-3 text-end actions text-nowrap">
    <div class="d-flex justify-content-end align-items-center gap-2">
      <%= link_to patient,
          class: "btn btn-sm btn-outline-primary",
          data: { role: "show-link" } do %>
        Show
      <% end %>

      <%= link_to edit_patient_path(patient),
          class: "btn btn-sm btn-outline-secondary",
          data: { role: "edit-link" } do %>
        Edit
      <% end %>

      <%= button_to patient,
          method: :delete,
          form: {
            data: {
              entry_id: patient.id,
              role: "delete-button",
              url: patient_path(patient),
              turbo_confirm: "Удалить пациента и все его данные?"
            },
            class: "d-inline"
          },
          class: "btn btn-sm btn-outline-danger" do %>
        Destroy
      <% end %>
    </div>
  </td>
</tr>
