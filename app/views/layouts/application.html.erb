<!DOCTYPE html>
<html>
  <head>
    <title>FortiDemo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">FortiDemo</a>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to patients_path, class: "nav-link #{"active" if controller_name == "patients"}" do %>
                <i class="bi bi-people me-1"></i> Посмотреть список Пациентов
              <% end %>
            </li>

            <li class="nav-item">
              <%= link_to recipes_path, class: "nav-link #{"active" if controller_name == "recipes"}" do %>
                <i class="bi bi-file-earmark-medical me-1"></i> Посмотреть список Рецептов
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <%= yield %>
  </body>
</html>
