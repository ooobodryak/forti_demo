<%# Форма поиска Рецептов
  #
  # Обязательные.
  # @param [Ransack::Search] q
%>

<div class="search-form-container mb-3 border rounded p-2 bg-light shadow-sm" style="max-width: 1100px;">
  <%= search_form_for q, url: recipes_path, method: :get, data: { resource_target: "search_form", action: "submit->resource#search" } do |f| %>

    <div class="row g-2 align-items-end">

    <div class="col-md-3">
      <%= f.label :with_drugs, "Список лекарств (через запятую)", class: "form-label small mb-1 fw-semibold" %>
      <%= f.search_field :with_drugs, class: "form-control form-control-sm", placeholder: "Аспирин, Морфин..." %>
    </div>

      <div class="col-md-3">
        <%= f.label :patient_id_eq, "Пациент", class: "form-label small mb-1 fw-semibold" %>
        <%= f.collection_select :patient_id_eq,
                                Patient.order(:first_name), :id, :name_with_id,
                                { include_blank: "Все пациенты" },
                                { class: "form-select form-select-sm js-searchable" } %>
      </div>

      <div class="col-md-2">
        <%= f.label :difficulty_type_eq, "Сложность", class: "form-label small mb-1 fw-semibold" %>
        <%= f.select :difficulty_type_eq,
                     [["Все", nil], ["Простой", "simple"], ["Сложный", "hard"]],
                     {},
                     { class: "form-select form-select-sm" } %>
      </div>

      <div class="col-md-4">
        <label class="form-label small mb-1 fw-semibold">Период действия (с какой даты по какую)</label>
        <div class="input-group input-group-sm">
          <%= f.date_field :start_at_gteq, class: "form-control", placeholder: "С" %>
          <%= f.date_field :start_at_lteq, class: "form-control", placeholder: "По" %>
        </div>
      </div>

      <div class="col-md-2 mt-2">
        <%= f.submit "Найти", class: "btn btn-sm btn-primary w-100" %>
      </div>

      <div class="col-md-2 mt-2">
        <%= link_to "Сбросить", recipes_path, class: "btn btn-sm btn-link text-decoration-none p-0 pb-1" %>
      </div>

    </div>
  <% end %>
</div>
